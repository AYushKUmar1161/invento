# Database Configuration
# For local dev: postgresql://postgres:postgrespassword@localhost:5432/inventory_db
# For Docker: postgresql://postgres:postgrespassword@postgres:5432/inventory_db
DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/inventory_db

# Security & CORS Settings
SECRET_KEY=your-super-secret-key-for-development-use-only
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80,http://localhost
